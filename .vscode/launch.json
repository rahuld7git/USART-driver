{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32F407 (OpenOCD + ST-Link)",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/USART_Example.elf",
      "armToolchainPath": "/Applications/ArmGNUToolchain/14.2.rel1/arm-none-eabi/bin",
      "servertype": "openocd",
      "serverpath": "/opt/homebrew/bin/openocd",
      "searchDir": [
        "/opt/homebrew/share/openocd/scripts"
      ],
      "interface": "swd",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      "preLaunchTask": "make: build",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw",
      "openOCDLaunchCommands": [
        "init",
        "reset init"
      ]
    }
  ]
}
